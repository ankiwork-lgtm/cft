{
  "name": "carbon-footprint-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Carbon Footprint Awareness Web App - MVP",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspace=shared --workspace=backend",
    "build:all": "npm run build --workspaces --if-present",
    "build:backend": "npm run build --workspace=shared --workspace=backend",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "browserslist": "^4.28.2",
    "caniuse-lite": "^1.0.30001799",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "uuid": "^11.0.3",
    "gaxios": {
      "uuid": "^11.0.3"
    },
    "teeny-request": {
      "uuid": "^11.0.3"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/carbon-footprint-tracker.git"
  },
  "keywords": [
    "carbon-footprint",
    "sustainability",
    "climate",
    "firebase",
    "react",
    "typescript"
  ],
  "author": "Your Name",
  "license": "MIT"
}
