rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - users can only read/write their own profile
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Prevent deletion for data integrity
      
      // Activity logs subcollection - users can only access their own entries
      match /entries/{entryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }
    
    // Emission factors - readable by any authenticated user, writable by no one
    match /emissionFactors/{factorId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only backend/admin can write
    }
    
    // Tip templates - readable by any authenticated user, writable by no one
    match /tips/{tipId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only backend/admin can write
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}